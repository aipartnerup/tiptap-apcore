FROM node:20-alpine

WORKDIR /app

# Copy root package files for tiptap-apcore (linked dependency)
COPY package.json package-lock.json* pnpm-lock.yaml* ./
COPY src/ ./src/
COPY tsconfig.json ./

# Build root package
RUN npm install --ignore-scripts && npm run build

# Copy demo package files
COPY demo/package.json ./demo/
WORKDIR /app/demo
RUN npm install

# Copy demo source
COPY demo/ ./

EXPOSE 5173

CMD ["npx", "vite", "--host", "0.0.0.0"]
